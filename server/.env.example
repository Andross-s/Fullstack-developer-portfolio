# Port the Express server listens on
PORT=4000

# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGIN=http://localhost:3000

# SMTP configuration used by Nodemailer to send contact-form emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-smtp-app-password

# Mailbox that receives contact-form submissions
CONTACT_RECEIVER_EMAIL=andrey.andross@gmail.com
