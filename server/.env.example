# Port the Express server listens on
PORT=4000

# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGIN=http://localhost:3000

# Resend (https://resend.com) API key used to send contact-form emails.
# Raw SMTP doesn't work here because most PaaS free tiers (e.g. Render)
# block outbound SMTP ports; Resend delivers over HTTPS instead.
RESEND_API_KEY=your-resend-api-key

# Sender address for outgoing emails. The default (onboarding@resend.dev)
# works without domain verification but can only send to the email address
# that owns the Resend account. Verify a custom domain in Resend to send
# from your own address instead.
RESEND_FROM_EMAIL=Portfolio Contact Form <onboarding@resend.dev>

# Mailbox that receives contact-form submissions
CONTACT_RECEIVER_EMAIL=andross_s@ukr.net
